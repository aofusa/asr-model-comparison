# Rust/Tauri runtime model cache (keep directory only)
app/models/**
!app/models/
!app/models/.gitkeep
app/src-tauri/models/**
!app/src-tauri/models/
!app/src-tauri/models/.gitkeep

# Explicitly allow our Pydantic models directory
!backend/app/models/
!backend/app/models/*.py

